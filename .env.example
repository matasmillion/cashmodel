# Foreign Resource — local development environment.
# Copy to .env.local (gitignored) and fill in real values.
# NEVER commit .env.local — it's already in .gitignore.

# ──────────────────────────────────────────────────────────────────────
# Clerk — Authentication
# ──────────────────────────────────────────────────────────────────────

# Frontend (safe to expose; lives in the SPA bundle on every deploy)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# Server only — set on Supabase Edge Function secrets, NEVER prefix VITE_,
# NEVER commit, NEVER paste here. Listed for documentation only.
#
#   supabase secrets set CLERK_SECRET_KEY=sk_test_...
#   supabase secrets set CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# ──────────────────────────────────────────────────────────────────────
# Supabase — Database (frontend, public anon key)
# ──────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
